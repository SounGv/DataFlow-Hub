# Database
DATABASE_URL=postgresql://dataflow:dataflow@localhost:5432/dataflow_hub?schema=public

# Redis (queue + SSE pub/sub + token denylist)
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Google Sheets — LINK-SHARE MODE (ไม่ต้องใช้ Google Cloud)
# 1. เปิดชีต → Share → General access → "Anyone with the link" (Viewer)
# 2. เอา ID จาก URL: https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=your-google-spreadsheet-id

# Sync
SYNC_CRON_MINUTES=15
SYNC_CHUNK_SIZE=1000

# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173
